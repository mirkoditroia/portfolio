rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Immagini - lettura pubblica, scrittura solo autenticati
    match /images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Video - lettura pubblica, scrittura solo autenticati
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Downloads - lettura pubblica, scrittura solo autenticati
    match /downloads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Assets - lettura pubblica, scrittura solo autenticati
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Test files - per debugging
    match /test/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Blocca tutto il resto
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
